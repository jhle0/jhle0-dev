---
import "../styles/global.css";
import "katex/dist/katex.min.css";
import {
  getLocaleFromPath,
  localizePath,
  stripLocaleFromPath,
  ui,
} from "../lib/i18n";

const {
  title = "jhle0",
  description = "Personal developer blog",
  canonicalPath,
  ogImage,
  ogType = "website",
  noindex = false,
  publishedTime,
  modifiedTime,
  locale: localeProp,
} = Astro.props;
const currentPath = Astro.url.pathname;
const locale = localeProp ?? getLocaleFromPath(currentPath);
const localeUi = ui[locale];
const siteOrigin = (Astro.site ?? Astro.url).origin;
const normalizedCanonicalPath = canonicalPath ?? Astro.url.pathname;
const canonicalUrl = new URL(normalizedCanonicalPath, siteOrigin).toString();
const ogImageUrl = new URL(ogImage ?? "/og/site.svg", siteOrigin).toString();
const basePath = stripLocaleFromPath(currentPath);
const koreanUrl = new URL(localizePath("ko", basePath), siteOrigin).toString();
const englishUrl = new URL(localizePath("en", basePath), siteOrigin).toString();
const themeUi = localeUi.theme;

const navItems = [
  { href: localizePath(locale, "/"), label: localeUi.nav.home },
  { href: localizePath(locale, "/about"), label: localeUi.nav.about },
  { href: localizePath(locale, "/now"), label: localeUi.nav.now },
  { href: localizePath(locale, "/blog"), label: localeUi.nav.blog },
  { href: localizePath(locale, "/projects"), label: localeUi.nav.projects },
  { href: localizePath(locale, "/contact"), label: localeUi.nav.contact },
];
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="zF0X_QA2U2-c1sKtm_fqHJZ95rNKm7NBFXlo47TsRtQ" />
    <link rel="canonical" href={canonicalUrl} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="jhle0 blog RSS"
      href={new URL("/rss.xml", siteOrigin).toString()}
    />

    <meta property="og:site_name" content="jhle0" />
    <meta property="og:locale" content={locale === "ko" ? "ko_KR" : "en_US"} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="color-scheme" content="light dark" />
    <link rel="alternate" hreflang="ko" href={koreanUrl} />
    <link rel="alternate" hreflang="en" href={englishUrl} />
    <link rel="alternate" hreflang="x-default" href={koreanUrl} />
    <script is:inline>
      (() => {
        const storageKey = "jhle0-theme";
        const root = document.documentElement;

        try {
          const saved = localStorage.getItem(storageKey);
          const preference =
            saved === "light" || saved === "dark" ? saved : "system";
          const resolvedTheme =
            preference === "system"
              ? window.matchMedia("(prefers-color-scheme: dark)").matches
                ? "dark"
                : "light"
              : preference;

          root.dataset.themePreference = preference;
          root.dataset.resolvedTheme = resolvedTheme;

          if (preference === "light" || preference === "dark") {
            root.dataset.theme = preference;
            root.style.colorScheme = preference;
            return;
          }

          root.removeAttribute("data-theme");
          root.style.colorScheme = window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";
        } catch {
          root.dataset.themePreference = "system";
          root.dataset.resolvedTheme = window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";
        }
      })();
    </script>

    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {noindex && <meta name="robots" content="noindex,nofollow" />}
  </head>
  <body>
    <a class="skip-link" href="#main-content">{localeUi.skipToContent}</a>
    <header class="site-header">
      <div class="site-shell">
        <nav class="site-nav" aria-label="Primary">
          <a class="site-brand" href={localizePath(locale, "/")}>jhle0</a>

          <div class="site-nav-meta">
            <div class="site-nav-links">
              {
                navItems.map((item) => {
                  const isActive =
                    item.href === localizePath(locale, "/")
                      ? currentPath === item.href
                      : currentPath === item.href ||
                        currentPath.startsWith(`${item.href}/`);

                  return (
                    <a
                      href={item.href}
                      class:list={[
                        "site-nav-link",
                        isActive && "is-active",
                      ]}
                      aria-current={isActive ? "page" : undefined}
                    >
                      {item.label}
                    </a>
                  );
                })
              }
            </div>

            <div class="site-locale-switcher" aria-label="Language switcher">
              <a
                href={localizePath("ko", basePath)}
                class:list={["site-locale-link", locale === "ko" && "is-active"]}
              >
                KO
              </a>
              <a
                href={localizePath("en", basePath)}
                class:list={["site-locale-link", locale === "en" && "is-active"]}
              >
                EN
              </a>
            </div>

            <button
              type="button"
              class="site-theme-toggle"
              data-theme-toggle
              aria-label={themeUi.toggleToDark}
              title={themeUi.toggleToDark}
              data-label-light={themeUi.toggleToLight}
              data-label-dark={themeUi.toggleToDark}
            >
              <span class="site-theme-toggle-track" aria-hidden="true">
                <span class="site-theme-toggle-thumb"></span>
                <span class="site-theme-icon site-theme-icon-sun">☀</span>
                <span class="site-theme-icon site-theme-icon-moon">☾</span>
              </span>
            </button>
          </div>
        </nav>
      </div>
    </header>

    <main id="main-content" class="site-main site-shell">
      <slot />
    </main>

    <footer class="site-footer site-shell">
      <div class="site-footer-brand">
        <a class="site-footer-logo" href="/">jhle0</a>
        <p>{localeUi.footer.description}</p>
        <p class="site-footer-copyright">
          © 2026 Lee Jeonghyeon. All rights reserved.
        </p>
      </div>

      <div class="site-footer-meta">
        <nav class="site-footer-links" aria-label="Footer">
          <a href={localizePath(locale, "/blog")}>Blog</a>
          <a href={localizePath(locale, "/projects")}>Projects</a>
          <a href="/rss.xml">RSS</a>
          <a href="https://github.com/jhle0" target="_blank" rel="noreferrer">
            GitHub
          </a>
        </nav>

        <p class="site-footer-built">
          {localeUi.footer.builtWith}
        </p>
      </div>
    </footer>
    <script is:inline>
      (() => {
        const storageKey = "jhle0-theme";
        const root = document.documentElement;
        const toggleButton = document.querySelector("[data-theme-toggle]");
        const media = window.matchMedia("(prefers-color-scheme: dark)");

        function getStoredPreference() {
          try {
            const saved = localStorage.getItem(storageKey);
            return saved === "light" || saved === "dark" ? saved : "system";
          } catch {
            return "system";
          }
        }

        function getResolvedTheme(preference) {
          return preference === "system"
            ? media.matches
              ? "dark"
              : "light"
            : preference;
        }

        function applyTheme(preference) {
          const resolvedTheme = getResolvedTheme(preference);
          root.dataset.themePreference = preference;
          root.dataset.resolvedTheme = resolvedTheme;

          if (preference === "light" || preference === "dark") {
            root.dataset.theme = preference;
            root.style.colorScheme = preference;
          } else {
            root.removeAttribute("data-theme");
            root.style.colorScheme = resolvedTheme;
          }

          if (toggleButton instanceof HTMLButtonElement) {
            toggleButton.dataset.resolvedTheme = resolvedTheme;
            toggleButton.setAttribute(
              "aria-pressed",
              resolvedTheme === "dark" ? "true" : "false",
            );

            const nextLabel =
              resolvedTheme === "dark"
                ? toggleButton.dataset.labelLight
                : toggleButton.dataset.labelDark;

            if (nextLabel) {
              toggleButton.setAttribute("aria-label", nextLabel);
              toggleButton.setAttribute("title", nextLabel);
            }
          }
        }

        const initialPreference = getStoredPreference();
        applyTheme(initialPreference);

        if (toggleButton instanceof HTMLButtonElement) {
          toggleButton.addEventListener("click", () => {
            const currentPreference = getStoredPreference();
            const resolvedTheme = getResolvedTheme(currentPreference);
            const nextPreference = resolvedTheme === "dark" ? "light" : "dark";

            try {
              localStorage.setItem(storageKey, nextPreference);
            } catch {}

            applyTheme(nextPreference);
          });
        }

        media.addEventListener("change", () => {
          if (getStoredPreference() === "system") {
            applyTheme("system");
          }
        });
      })();
    </script>
  </body>
</html>
