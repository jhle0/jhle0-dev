---
import "../styles/global.css";
import "katex/dist/katex.min.css";

const {
  title = "jhle0",
  description = "Personal developer blog",
  canonicalPath,
  ogImage,
  ogType = "website",
  noindex = false,
  publishedTime,
  modifiedTime,
} = Astro.props;
const currentPath = Astro.url.pathname;
const siteOrigin = (Astro.site ?? Astro.url).origin;
const normalizedCanonicalPath = canonicalPath ?? Astro.url.pathname;
const canonicalUrl = new URL(normalizedCanonicalPath, siteOrigin).toString();
const ogImageUrl = new URL(ogImage ?? "/og/site.svg", siteOrigin).toString();

const navItems = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/now", label: "Now" },
  { href: "/blog", label: "Blog" },
  { href: "/projects", label: "Projects" },
  { href: "/contact", label: "Contact" },
];
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="zF0X_QA2U2-c1sKtm_fqHJZ95rNKm7NBFXlo47TsRtQ" />
    <link rel="canonical" href={canonicalUrl} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="jhle0 blog RSS"
      href={new URL("/rss.xml", siteOrigin).toString()}
    />

    <meta property="og:site_name" content="jhle0" />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {noindex && <meta name="robots" content="noindex,nofollow" />}
  </head>
  <body>
    <a class="skip-link" href="#main-content">본문으로 건너뛰기</a>
    <header class="site-header">
      <div class="site-shell">
        <nav class="site-nav" aria-label="Primary">
          <a class="site-brand" href="/">jhle0</a>

          <div class="site-nav-links">
            {
              navItems.map((item) => {
                const isActive =
                  item.href === "/"
                    ? currentPath === "/"
                    : currentPath === item.href ||
                      currentPath.startsWith(`${item.href}/`);

                return (
                  <a
                    href={item.href}
                    class:list={[
                      "site-nav-link",
                      isActive && "is-active",
                    ]}
                    aria-current={isActive ? "page" : undefined}
                  >
                    {item.label}
                  </a>
                );
              })
            }
          </div>
        </nav>
      </div>
    </header>

    <main id="main-content" class="site-main site-shell">
      <slot />
    </main>

    <footer class="site-footer site-shell">
      <div class="site-footer-brand">
        <a class="site-footer-logo" href="/">jhle0</a>
        <p>CS와 AI를 공부하며 쌓아가는 개인 개발 블로그.</p>
        <p class="site-footer-copyright">
          © 2026 Lee Jeonghyeon. All rights reserved.
        </p>
      </div>

      <div class="site-footer-meta">
        <nav class="site-footer-links" aria-label="Footer">
          <a href="/blog">Blog</a>
          <a href="/projects">Projects</a>
          <a href="/rss.xml">RSS</a>
          <a href="https://github.com/jhle0" target="_blank" rel="noreferrer">
            GitHub
          </a>
        </nav>

        <p class="site-footer-built">
          Built with Astro · Deployed on Vercel
        </p>
      </div>
    </footer>
  </body>
</html>
