---
import "../styles/global.css";
import "katex/dist/katex.min.css";
import {
  getLocaleFromPath,
  localizePath,
  stripLocaleFromPath,
  ui,
} from "../lib/i18n";

const {
  title = "jhle0",
  description = "Personal developer blog",
  canonicalPath,
  ogImage,
  ogType = "website",
  noindex = false,
  publishedTime,
  modifiedTime,
  locale: localeProp,
} = Astro.props;
const currentPath = Astro.url.pathname;
const locale = localeProp ?? getLocaleFromPath(currentPath);
const localeUi = ui[locale];
const siteOrigin = (Astro.site ?? Astro.url).origin;
const normalizedCanonicalPath = canonicalPath ?? Astro.url.pathname;
const canonicalUrl = new URL(normalizedCanonicalPath, siteOrigin).toString();
const ogImageUrl = new URL(ogImage ?? "/og/site.svg", siteOrigin).toString();
const basePath = stripLocaleFromPath(currentPath);
const koreanUrl = new URL(localizePath("ko", basePath), siteOrigin).toString();
const englishUrl = new URL(localizePath("en", basePath), siteOrigin).toString();

const navItems = [
  { href: localizePath(locale, "/"), label: localeUi.nav.home },
  { href: localizePath(locale, "/about"), label: localeUi.nav.about },
  { href: localizePath(locale, "/now"), label: localeUi.nav.now },
  { href: localizePath(locale, "/blog"), label: localeUi.nav.blog },
  { href: localizePath(locale, "/projects"), label: localeUi.nav.projects },
  { href: localizePath(locale, "/contact"), label: localeUi.nav.contact },
];
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="zF0X_QA2U2-c1sKtm_fqHJZ95rNKm7NBFXlo47TsRtQ" />
    <link rel="canonical" href={canonicalUrl} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="jhle0 blog RSS"
      href={new URL("/rss.xml", siteOrigin).toString()}
    />

    <meta property="og:site_name" content="jhle0" />
    <meta property="og:locale" content={locale === "ko" ? "ko_KR" : "en_US"} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="alternate" hreflang="ko" href={koreanUrl} />
    <link rel="alternate" hreflang="en" href={englishUrl} />
    <link rel="alternate" hreflang="x-default" href={koreanUrl} />

    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {noindex && <meta name="robots" content="noindex,nofollow" />}
  </head>
  <body>
    <a class="skip-link" href="#main-content">{localeUi.skipToContent}</a>
    <header class="site-header">
      <div class="site-shell">
        <nav class="site-nav" aria-label="Primary">
          <a class="site-brand" href={localizePath(locale, "/")}>jhle0</a>

          <div class="site-nav-meta">
            <div class="site-nav-links">
              {
                navItems.map((item) => {
                  const isActive =
                    item.href === localizePath(locale, "/")
                      ? currentPath === item.href
                      : currentPath === item.href ||
                        currentPath.startsWith(`${item.href}/`);

                  return (
                    <a
                      href={item.href}
                      class:list={[
                        "site-nav-link",
                        isActive && "is-active",
                      ]}
                      aria-current={isActive ? "page" : undefined}
                    >
                      {item.label}
                    </a>
                  );
                })
              }
            </div>

            <div class="site-locale-switcher" aria-label="Language switcher">
              <a
                href={localizePath("ko", basePath)}
                class:list={["site-locale-link", locale === "ko" && "is-active"]}
              >
                KO
              </a>
              <a
                href={localizePath("en", basePath)}
                class:list={["site-locale-link", locale === "en" && "is-active"]}
              >
                EN
              </a>
            </div>
          </div>
        </nav>
      </div>
    </header>

    <main id="main-content" class="site-main site-shell">
      <slot />
    </main>

    <footer class="site-footer site-shell">
      <div class="site-footer-brand">
        <a class="site-footer-logo" href="/">jhle0</a>
        <p>{localeUi.footer.description}</p>
        <p class="site-footer-copyright">
          © 2026 Lee Jeonghyeon. All rights reserved.
        </p>
      </div>

      <div class="site-footer-meta">
        <nav class="site-footer-links" aria-label="Footer">
          <a href={localizePath(locale, "/blog")}>Blog</a>
          <a href={localizePath(locale, "/projects")}>Projects</a>
          <a href="/rss.xml">RSS</a>
          <a href="https://github.com/jhle0" target="_blank" rel="noreferrer">
            GitHub
          </a>
        </nav>

        <p class="site-footer-built">
          {localeUi.footer.builtWith}
        </p>
      </div>
    </footer>
  </body>
</html>
