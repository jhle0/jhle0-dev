---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  locale="en"
  title="Contact | jhle0"
  description="Contact information"
  canonicalPath="/en/contact"
>
  <section class="page-intro">
    <p class="eyebrow">Contact</p>
    <h1>Ways to reach me</h1>
    <p class="intro-copy">
      Collaboration, feedback, study conversations, or even a light hello are
      all welcome. Reach out through the channel that feels most comfortable.
    </p>
  </section>

  <section class="section-block">
    <ul class="contact-grid">
      <li class="surface-card contact-card">
        <p class="contact-label">Best for</p>
        <h2>Email</h2>
        <p class="contact-value">dumiso04@gmail.com</p>
        <p class="contact-copy">
          The most convenient channel for collaboration inquiries, feedback,
          questions, or personal messages.
        </p>
        <a class="button-link" href="mailto:dumiso04@gmail.com">
          Send email
        </a>
      </li>
      <li class="surface-card contact-card">
        <p class="contact-label">Code & Archive</p>
        <h2>GitHub</h2>
        <p class="contact-value">@jhle0</p>
        <p class="contact-copy">
          This is where my project records, code, and implementation flow live.
          It is the most natural place to see the context behind what I build.
        </p>
        <a
          class="button-link"
          href="https://github.com/jhle0"
          target="_blank"
          rel="noreferrer"
        >
          Visit GitHub
        </a>
      </li>
      <li class="surface-card contact-card">
        <p class="contact-label">Social</p>
        <h2>LinkedIn</h2>
        <p class="contact-value">Coming soon</p>
        <p class="contact-copy">
          I have not opened it yet. When I do, it will be used for organizing
          career history and public-facing activity.
        </p>
        <span class="contact-muted">A link will be added later</span>
      </li>
    </ul>
  </section>
</BaseLayout>
