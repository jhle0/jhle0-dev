---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const projects = (await getCollection("projects"))
  .filter((project) => !project.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
---

<BaseLayout
  locale="en"
  title="Home | jhle0"
  description="A personal developer archive built around CS and AI."
  canonicalPath="/en/"
>
  <section class="home-hero">
    <p class="eyebrow">Developer archive</p>
    <h1>
      <span class="home-hero-title-line">A personal archive</span>
      <span class="home-hero-title-line">built while studying</span>
      <span class="home-hero-title-line">CS and AI.</span>
    </h1>
    <p class="home-hero-kicker">
      CS fundamentals / AI learning / project notes
    </p>
    <div class="home-hero-actions">
      <a class="home-action-link is-primary" href="/en/blog">View Blog</a>
      <a class="home-action-link" href="/en/about">About</a>
      <a class="home-action-link" href="/en/projects">View Projects</a>
    </div>
  </section>

  <section class="section-block">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Recent writing</p>
        <h2>Recent Posts</h2>
        <p class="section-copy">
          Notes from study sessions, implementation logs, and reflections
          gathered into one archive.
        </p>
      </div>
      <a class="text-link" href="/en/blog">View all posts</a>
    </div>
    {
      posts.length === 0 ? (
        <p class="empty-copy">No published posts yet.</p>
      ) : (
        <ul class="feature-grid">
          {posts.map((post) => (
            <li class="surface-card">
              <article class="stack-sm">
                <p class="meta">
                  {post.data.pubDate.toISOString().slice(0, 10)}
                </p>
                <h3>
                  <a href={`/en/blog/${post.data.slug}`}>{post.data.title}</a>
                </h3>
                <p>{post.data.description}</p>
                <ul class="tag-list">
                  {post.data.tags.slice(0, 3).map((tag) => (
                    <li>
                      <a href={`/en/tags/${tag}`}>{tag}</a>
                    </li>
                  ))}
                </ul>
              </article>
            </li>
          ))}
        </ul>
      )
    }
  </section>

  <section class="section-block">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Selected builds</p>
        <h2>Recent Projects</h2>
        <p class="section-copy">
          Projects documented not only by results, but by design decisions,
          process, and lessons learned.
        </p>
      </div>
      <a class="text-link" href="/en/projects">View all projects</a>
    </div>
    {
      projects.length === 0 ? (
        <p class="empty-copy">No published projects yet.</p>
      ) : (
        <ul class="feature-grid">
          {projects.map((project) => (
            <li class="surface-card">
              <article class="stack-sm">
                <p class="meta">
                  {project.data.pubDate.toISOString().slice(0, 10)}
                  {project.data.status && (
                    <>
                      {" "}
                      · <strong>{project.data.status}</strong>
                    </>
                  )}
                </p>
                <h3>
                  <a href={`/en/projects/${project.data.slug}`}>
                    {project.data.title}
                  </a>
                </h3>
                <p>{project.data.description}</p>
                <ul class="tag-list">
                  {project.data.tags.slice(0, 3).map((tag) => (
                    <li>
                      <span class="tag">{tag}</span>
                    </li>
                  ))}
                </ul>
              </article>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>
