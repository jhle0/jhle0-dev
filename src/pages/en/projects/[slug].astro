---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");

  return projects
    .filter((project) => !project.data.draft)
    .map((project) => ({
      params: { slug: project.data.slug },
      props: { project },
    }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const formatStatus = (status?: string) =>
  !status ? null : status.replace("-", " ");
---

<BaseLayout
  locale="en"
  title={`${project.data.title} | jhle0`}
  description={project.data.description}
  canonicalPath={`/en/projects/${project.data.slug}`}
  ogImage={`/og/projects/${project.data.slug}.svg`}
  modifiedTime={(project.data.updatedDate ?? project.data.pubDate).toISOString()}
>
  <article class="entry-article">
    <header class="page-intro">
      <div class="entry-meta-row">
        <p class="meta">{project.data.pubDate.toISOString().slice(0, 10)}</p>
        {project.data.status && (
          <span class="status-pill">{formatStatus(project.data.status)}</span>
        )}
      </div>
      <h1>{project.data.title}</h1>
      <p class="intro-copy">{project.data.description}</p>

      {project.data.tags.length > 0 && (
        <ul class="tag-list">
          {project.data.tags.map((tag) => (
            <li>
              <span class="tag">{tag}</span>
            </li>
          ))}
        </ul>
      )}

      <ul class="card-links">
        {project.data.githubUrl && project.data.githubUrl !== "" && (
          <li>
            <a href={project.data.githubUrl} target="_blank" rel="noreferrer">
              GitHub
            </a>
          </li>
        )}
        {project.data.demoUrl && project.data.demoUrl !== "" && (
          <li>
            <a href={project.data.demoUrl} target="_blank" rel="noreferrer">
              Demo
            </a>
          </li>
        )}
      </ul>
    </header>

    <div class="article-content">
      <Content />
    </div>

    <div class="entry-actions">
      <a class="text-link" href="/en/projects">Back to projects</a>
    </div>
  </article>
</BaseLayout>
