---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const projects = (await getCollection("projects"))
  .filter((project) => !project.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
---

<BaseLayout
  title="Home | jhle0"
  description="Study notes, projects, and logs in one place."
>
  <section class="home-hero">
    <p class="eyebrow">Developer archive</p>
    <h1>
      CS와 AI를
      <br />
      공부하며 쌓아가는
      <br />
      개인 개발 아카이브입니다.
    </h1>
    <p class="hero-lead">
      CS와 AI를 공부하며 쌓아가는 개인 개발 아카이브입니다.
      공부 노트, 프로젝트 기록, 그리고 그 과정에서의 회고를 정리합니다.
    </p>
    <p class="home-hero-kicker">
      CS fundamentals / AI learning / project notes
    </p>
    <div class="home-hero-actions">
      <a class="home-action-link is-primary" href="/blog">View Blog</a>
      <a class="home-action-link" href="/about">About</a>
      <a class="home-action-link" href="/projects">View Projects</a>
    </div>
  </section>

  <section class="section-block">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Recent writing</p>
        <h2>Recent Posts</h2>
        <p class="section-copy">
          공부하며 바로 기록한 메모와, 구현하면서 정리한 생각들을 모아둔 글들.
        </p>
      </div>
      <a class="text-link" href="/blog">View all posts</a>
    </div>
    {
      posts.length === 0 ? (
        <p class="empty-copy">No published posts yet.</p>
      ) : (
        <ul class="feature-grid">
          {posts.map((post) => (
            <li class="surface-card">
              <article class="stack-sm">
                <p class="meta">
                  {post.data.pubDate.toISOString().slice(0, 10)}
                </p>
                <h3>
                  <a href={`/blog/${post.data.slug}`}>{post.data.title}</a>
                </h3>
                <p>{post.data.description}</p>
                <ul class="tag-list">
                  {post.data.tags.slice(0, 3).map((tag) => (
                    <li>
                      <a href={`/tags/${tag}`}>{tag}</a>
                    </li>
                  ))}
                </ul>
              </article>
            </li>
          ))}
        </ul>
      )
    }
  </section>

  <section class="section-block">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Selected builds</p>
        <h2>Recent Projects</h2>
        <p class="section-copy">
          구현 자체보다도 설계 과정과 회고가 남도록 정리한 작업들.
        </p>
      </div>
      <a class="text-link" href="/projects">View all projects</a>
    </div>
    {
      projects.length === 0 ? (
        <p class="empty-copy">No published projects yet.</p>
      ) : (
        <ul class="feature-grid">
          {projects.map((project) => (
            <li class="surface-card">
              <article class="stack-sm">
                <p class="meta">
                  {project.data.pubDate.toISOString().slice(0, 10)}
                  {project.data.status && (
                    <>
                      {" "}
                      · <strong>{project.data.status}</strong>
                    </>
                  )}
                </p>
                <h3>
                  <a href={`/projects/${project.data.slug}`}>
                    {project.data.title}
                  </a>
                </h3>
                <p>{project.data.description}</p>
                <ul class="tag-list">
                  {project.data.tags.slice(0, 3).map((tag) => (
                    <li>
                      <span class="tag">{tag}</span>
                    </li>
                  ))}
                </ul>
              </article>
            </li>
          ))}
        </ul>
      )
    }
  </section>

</BaseLayout>
