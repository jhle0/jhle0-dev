---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const projects = (await getCollection("projects"))
  .filter((project) => !project.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
---

<BaseLayout
  title="Home | jhle0"
  description="Study notes, projects, and logs in one place."
>
  <section class="home-hero">
    <p class="eyebrow">Developer archive</p>
    <h1>CS와 AI를 공부하고, 만든 것을 기록하는 개인 개발 아카이브.</h1>
    <p class="hero-lead">
      공부 메모, 프로젝트 회고, 구현 기록, 그리고 지금 집중하고 있는 작업을
      차분하게 쌓아가는 공간이다.
    </p>
    <div class="home-hero-actions">
      <a class="button-link" href="/blog">Read the blog</a>
      <a class="button-link is-secondary" href="/about">About me</a>
      <a class="text-link" href="/projects">Browse projects</a>
    </div>
    <ul class="home-summary-list">
      <li>CS, 네트워크, AI 중심의 학습 기록</li>
      <li>프로젝트 구현 과정과 회고 아카이브</li>
      <li>현재 집중하는 작업은 Now 페이지에 정리</li>
    </ul>
    <div class="home-hero-meta surface-card">
      <div>
        <small>Recent posts</small>
        <strong>{posts.length}</strong>
      </div>
      <div>
        <small>Projects</small>
        <strong>{projects.length}</strong>
      </div>
      <div>
        <small>Focus</small>
        <strong>CS · AI · Build</strong>
      </div>
    </div>
  </section>

  <section class="section-block">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Recent writing</p>
        <h2>최근 글</h2>
        <p class="section-copy">
          공부하며 바로 기록한 메모와, 구현하면서 정리한 생각들을 모아둔 글들.
        </p>
      </div>
      <a class="text-link" href="/blog">전체 글 보기</a>
    </div>
    {
      posts.length === 0 ? (
        <p class="empty-copy">아직 공개된 글이 없습니다.</p>
      ) : (
        <ul class="feature-grid">
          {posts.map((post) => (
            <li class="surface-card">
              <article class="stack-sm">
                <p class="meta">
                  {post.data.pubDate.toISOString().slice(0, 10)}
                </p>
                <h3>
                  <a href={`/blog/${post.data.slug}`}>{post.data.title}</a>
                </h3>
                <p>{post.data.description}</p>
                <ul class="tag-list">
                  {post.data.tags.slice(0, 3).map((tag) => (
                    <li>
                      <a href={`/tags/${tag}`}>{tag}</a>
                    </li>
                  ))}
                </ul>
              </article>
            </li>
          ))}
        </ul>
      )
    }
  </section>

  <section class="section-block">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Selected builds</p>
        <h2>최근 프로젝트</h2>
        <p class="section-copy">
          구현 자체보다도 설계 과정과 회고가 남도록 정리한 작업들.
        </p>
      </div>
      <a class="text-link" href="/projects">전체 프로젝트 보기</a>
    </div>
    {
      projects.length === 0 ? (
        <p class="empty-copy">아직 공개된 프로젝트가 없습니다.</p>
      ) : (
        <ul class="feature-grid">
          {projects.map((project) => (
            <li class="surface-card">
              <article class="stack-sm">
                <p class="meta">
                  {project.data.pubDate.toISOString().slice(0, 10)}
                  {project.data.status && (
                    <>
                      {" "}
                      · <strong>{project.data.status}</strong>
                    </>
                  )}
                </p>
                <h3>
                  <a href={`/projects/${project.data.slug}`}>
                    {project.data.title}
                  </a>
                </h3>
                <p>{project.data.description}</p>
                <ul class="tag-list">
                  {project.data.tags.slice(0, 3).map((tag) => (
                    <li>
                      <span class="tag">{tag}</span>
                    </li>
                  ))}
                </ul>
              </article>
            </li>
          ))}
        </ul>
      )
    }
  </section>

  <section class="section-block">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Navigate</p>
        <h2>사이트 둘러보기</h2>
        <p class="section-copy">
          소개, 현재 상태, 연락 채널까지 한 번에 이어서 볼 수 있다.
        </p>
      </div>
    </div>
    <ul class="explore-grid">
      <li class="surface-card">
        <a class="explore-link" href="/about">
          <strong>About</strong>
          <span>소개, 관심사, 장기 방향</span>
        </a>
      </li>
      <li class="surface-card">
        <a class="explore-link" href="/now">
          <strong>Now</strong>
          <span>지금 집중하고 있는 공부와 작업</span>
        </a>
      </li>
      <li class="surface-card">
        <a class="explore-link" href="/contact">
          <strong>Contact</strong>
          <span>연락 가능한 채널과 기본 정보</span>
        </a>
      </li>
    </ul>
  </section>
</BaseLayout>
