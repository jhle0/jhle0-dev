---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import {
  BLOG_TOPIC_VALUES,
  getBlogTopicDescription,
  getBlogTopicLabel,
} from "../../lib/blog";

const posts = await getCollection("blog");
const publishedPosts = posts
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const topicSummaries = BLOG_TOPIC_VALUES.map((topic) => ({
  value: topic,
  label: getBlogTopicLabel(topic),
  description: getBlogTopicDescription(topic, "ko"),
  count: publishedPosts.filter((post) => post.data.topic === topic).length,
}));

const allTags = [...new Set(publishedPosts.flatMap((post) => post.data.tags))]
  .map((tag) => ({
    value: tag,
    count: publishedPosts.filter((post) => post.data.tags.includes(tag)).length,
  }))
  .sort((a, b) => b.count - a.count || a.value.localeCompare(b.value));

const initialVisibleTags = 12;
---

<BaseLayout
  title="Blog | jhle0"
  description="Study notes, project logs, and learning records."
  canonicalPath="/blog"
  ogImage="/og/site.svg"
>
  <section class="blog-archive-page">
    <header class="blog-archive-header page-intro">
      <p class="eyebrow">Archive</p>
      <h1>Blog</h1>
      <p class="intro-copy">
        공부한 개념, 만든 것의 기록, 그리고 중간 회고를 큰 주제와 세부 태그
        기준으로 함께 탐색할 수 있게 정리한 아카이브.
      </p>
    </header>

    <section class="blog-topic-panel surface-card">
      <p class="eyebrow">Topic</p>
      <div class="blog-topic-list" aria-label="Blog topics">
        <button
          type="button"
          class="blog-topic-button is-active"
          data-topic-filter="all"
        >
          <span>All</span>
          <small>{publishedPosts.length}</small>
        </button>

        {
          topicSummaries.map((topic) => (
            <button
              type="button"
              class="blog-topic-button"
              data-topic-filter={topic.value}
              title={topic.description}
            >
              <span>{topic.label}</span>
              <small>{topic.count}</small>
            </button>
          ))
        }
      </div>
    </section>

    <div class="blog-archive-layout">
      <aside class="blog-sidebar surface-card">
        <div class="blog-sidebar-section">
          <div class="blog-search-box">
            <span class="blog-search-icon" aria-hidden="true">⌕</span>
            <input
              id="blog-search"
              type="text"
              placeholder="Search posts"
              autocomplete="off"
            />
          </div>
        </div>

        <div class="blog-sidebar-section">
          <div class="blog-filter-header">
            <h2>Tags</h2>
            <button id="clear-filters" type="button">Reset</button>
          </div>

          <ul
            id="blog-tag-list"
            class="blog-filter-list blog-filter-list-compact"
          >
            {
              allTags.map((tag, index) => (
                <li class:list={["blog-tag-list-item", index >= initialVisibleTags && "is-collapsed"]}>
                  <label class="blog-filter-chip">
                    <input
                      type="checkbox"
                      value={tag.value}
                      class="blog-tag-checkbox"
                    />
                    <span>{tag.value}</span>
                    <small>{tag.count}</small>
                  </label>
                </li>
              ))
            }
          </ul>

          {allTags.length > initialVisibleTags && (
            <button
              id="toggle-tags"
              type="button"
              class="blog-filter-toggle"
              data-label-more="Show more tags"
              data-label-less="Show fewer tags"
            >
              Show more tags
            </button>
          )}
        </div>
      </aside>

      <div class="blog-content-area">
        <div class="blog-toolbar">
          <p id="blog-results-count">
            SHOWING {publishedPosts.length} OF {publishedPosts.length} POSTS
          </p>

          <div class="blog-toolbar-actions">
            <a class="text-link" href="/rss.xml">RSS</a>
            <button
              id="sort-toggle"
              type="button"
              class="blog-sort-button"
              data-order="desc"
            >
              DESCENDING
            </button>
          </div>
        </div>

        <ul id="blog-post-list" class="blog-post-card-list">
          {
            publishedPosts.map((post) => (
              <li
                class="blog-post-card"
                data-title={post.data.title.toLowerCase()}
                data-description={post.data.description.toLowerCase()}
                data-tags={post.data.tags.join(" ").toLowerCase()}
                data-topic={post.data.topic}
                data-date={post.data.pubDate.toISOString()}
              >
                <article>
                  <div class="blog-post-meta-row">
                    <div class="blog-post-kickers">
                      <a
                        class="topic-pill"
                        href={`/blog?topic=${post.data.topic}`}
                      >
                        {getBlogTopicLabel(post.data.topic)}
                      </a>
                      {post.data.series && (
                        <span class="blog-series-pill">{post.data.series}</span>
                      )}
                    </div>

                    <p class="blog-post-date">
                      {post.data.pubDate.toISOString().slice(0, 10)}
                    </p>
                  </div>

                  <div class="blog-post-main">
                    <div class="blog-post-text">
                      <h3>
                        <a href={`/blog/${post.data.slug}`}>
                          {post.data.title}
                        </a>
                      </h3>
                      <p>{post.data.description}</p>

                      <ul class="tag-list blog-post-tags">
                        {post.data.tags.slice(0, 4).map((tag) => (
                          <li>
                            <a href={`/tags/${tag}`}>{tag}</a>
                          </li>
                        ))}
                      </ul>
                    </div>

                    <div class="blog-post-arrow" aria-hidden="true">
                      ›
                    </div>
                  </div>
                </article>
              </li>
            ))
          }
        </ul>

        <p id="blog-empty-state" class="blog-empty-state" hidden style="display: none;">
          No posts match your current filters.
        </p>
      </div>
    </div>
  </section>

  <script is:inline>
    const searchInput = document.getElementById("blog-search");
    const clearButton = document.getElementById("clear-filters");
    const sortToggle = document.getElementById("sort-toggle");
    const resultsCount = document.getElementById("blog-results-count");
    const postList = document.getElementById("blog-post-list");
    const emptyState = document.getElementById("blog-empty-state");
    const checkboxes = Array.from(document.querySelectorAll(".blog-tag-checkbox"));
    const topicButtons = Array.from(
      document.querySelectorAll("[data-topic-filter]"),
    );
    const tagList = document.getElementById("blog-tag-list");
    const toggleTagsButton = document.getElementById("toggle-tags");
    const allCards = Array.from(document.querySelectorAll(".blog-post-card"));
    const totalCount = allCards.length;
    const availableTopics = new Set(
      topicButtons.map((button) => button.dataset.topicFilter || "all"),
    );

    const url = new URL(window.location.href);
    const queryFromUrl = (url.searchParams.get("q") || "").trim();
    const sortFromUrl = url.searchParams.get("sort");
    const topicFromUrl = (url.searchParams.get("topic") || "all")
      .trim()
      .toLowerCase();
    const tagsFromUrl = (url.searchParams.get("tags") || "")
      .split(",")
      .map((tag) => tag.trim().toLowerCase())
      .filter(Boolean);

    let sortOrder = sortFromUrl === "asc" ? "asc" : "desc";
    let activeTopic = availableTopics.has(topicFromUrl) ? topicFromUrl : "all";

    if (searchInput instanceof HTMLInputElement) {
      searchInput.value = queryFromUrl;
    }

    const initialTagSet = new Set(tagsFromUrl);
    checkboxes.forEach((checkbox) => {
      checkbox.checked = initialTagSet.has(checkbox.value.toLowerCase());
    });

    function getSelectedTags() {
      return checkboxes
        .filter((checkbox) => checkbox.checked)
        .map((checkbox) => checkbox.value.toLowerCase());
    }

    function updateActiveFilterStyles() {
      checkboxes.forEach((checkbox) => {
        const label = checkbox.closest(".blog-filter-chip");
        if (!label) return;
        label.classList.toggle("is-active", checkbox.checked);
      });
    }

    function updateActiveTopicStyles() {
      topicButtons.forEach((button) => {
        const isActive = button.dataset.topicFilter === activeTopic;
        button.classList.toggle("is-active", isActive);
        button.setAttribute("aria-pressed", isActive ? "true" : "false");
      });
    }

    function matchesSearch(card, query) {
      const haystack = [
        card.dataset.title || "",
        card.dataset.description || "",
        card.dataset.tags || "",
        card.dataset.topic || "",
      ].join(" ");

      return haystack.includes(query);
    }

    function matchesTopic(card) {
      if (activeTopic === "all") return true;
      return (card.dataset.topic || "").toLowerCase() === activeTopic;
    }

    function matchesTags(card, selectedTags) {
      if (selectedTags.length === 0) return true;
      const cardTags = (card.dataset.tags || "").split(" ").filter(Boolean);
      return selectedTags.every((tag) => cardTags.includes(tag));
    }

    function sortCards(cards) {
      return cards.sort((a, b) => {
        const aDate = new Date(a.dataset.date).getTime();
        const bDate = new Date(b.dataset.date).getTime();
        return sortOrder === "desc" ? bDate - aDate : aDate - bDate;
      });
    }

    function syncQueryString(query, selectedTags) {
      const nextUrl = new URL(window.location.href);

      if (query) {
        nextUrl.searchParams.set("q", query);
      } else {
        nextUrl.searchParams.delete("q");
      }

      if (activeTopic !== "all") {
        nextUrl.searchParams.set("topic", activeTopic);
      } else {
        nextUrl.searchParams.delete("topic");
      }

      if (selectedTags.length > 0) {
        nextUrl.searchParams.set("tags", selectedTags.join(","));
      } else {
        nextUrl.searchParams.delete("tags");
      }

      if (sortOrder === "asc") {
        nextUrl.searchParams.set("sort", "asc");
      } else {
        nextUrl.searchParams.delete("sort");
      }

      window.history.replaceState(
        null,
        "",
        `${nextUrl.pathname}${nextUrl.search}${nextUrl.hash}`,
      );
    }

    function render() {
      const query = ((searchInput instanceof HTMLInputElement ? searchInput.value : "") || "")
        .trim()
        .toLowerCase();
      const selectedTags = getSelectedTags();

      const filtered = allCards.filter((card) => {
        return (
          matchesSearch(card, query) &&
          matchesTopic(card) &&
          matchesTags(card, selectedTags)
        );
      });

      const sorted = sortCards([...filtered]);

      if (postList) {
        postList.innerHTML = "";
        sorted.forEach((card) => postList.appendChild(card));
      }

      if (resultsCount) {
        resultsCount.textContent = `SHOWING ${sorted.length} OF ${totalCount} POSTS`;
      }
      if (sortToggle) {
        sortToggle.textContent = sortOrder === "desc" ? "DESCENDING" : "ASCENDING";
      }

      const isEmpty = sorted.length === 0;
      if (emptyState) {
        emptyState.hidden = !isEmpty;
        emptyState.style.display = isEmpty ? "block" : "none";
      }

      updateActiveFilterStyles();
      updateActiveTopicStyles();
      syncQueryString(query, selectedTags);
    }

    clearButton?.addEventListener("click", () => {
      if (searchInput instanceof HTMLInputElement) {
        searchInput.value = "";
      }
      activeTopic = "all";
      checkboxes.forEach((checkbox) => {
        checkbox.checked = false;
      });
      render();
    });

    searchInput?.addEventListener("input", render);
    sortToggle?.addEventListener("click", () => {
      sortOrder = sortOrder === "desc" ? "asc" : "desc";
      render();
    });
    checkboxes.forEach((checkbox) => checkbox.addEventListener("change", render));
    topicButtons.forEach((button) => {
      button.addEventListener("click", () => {
        activeTopic = button.dataset.topicFilter || "all";
        render();
      });
    });

    toggleTagsButton?.addEventListener("click", () => {
      if (!tagList) return;

      const expanded = tagList.classList.toggle("is-expanded");
      const nextLabel = expanded
        ? toggleTagsButton.dataset.labelLess
        : toggleTagsButton.dataset.labelMore;

      if (nextLabel) {
        toggleTagsButton.textContent = nextLabel;
      }
    });

    render();
  </script>
</BaseLayout>
