---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const projects = await getCollection("projects");
const publishedProjects = projects
  .filter((project) => !project.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const formatStatus = (status?: string) =>
  !status
    ? null
    : status
        .split("-")
        .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
        .join(" ");
---

<BaseLayout title="Projects | jhle0" description="Projects archive">
  <section class="page-intro">
    <p class="eyebrow">Projects archive</p>
    <h1>Projects</h1>
    <p class="intro-copy">
      구현 결과뿐 아니라 어떤 문제를 풀었고 무엇을 배웠는지까지 남기는
      프로젝트 아카이브.
    </p>
  </section>

  <section class="section-block">
    {
      publishedProjects.length === 0 ? (
        <p class="empty-copy">아직 공개된 프로젝트가 없습니다.</p>
      ) : (
        <ul class="projects-archive-list">
          {publishedProjects.map((project) => (
            <li class="project-card surface-card">
              <article class="project-card-layout">
                <a
                  class="project-card-visual"
                  href={`/projects/${project.data.slug}`}
                  aria-label={`${project.data.title} 프로젝트 보기`}
                >
                  {project.data.heroImage && project.data.heroImage !== "" ? (
                    <img
                      class="project-card-image"
                      src={project.data.heroImage}
                      alt={`${project.data.title} preview`}
                      loading="lazy"
                    />
                  ) : (
                    <div class="project-card-placeholder">
                      <p class="project-card-placeholder-kicker">Project</p>
                      <strong>{project.data.title}</strong>
                      <span>{project.data.pubDate.toISOString().slice(0, 4)}</span>
                    </div>
                  )}

                  <div class="project-card-visual-overlay">
                    <span class="project-card-visual-kicker">Archive</span>
                    {project.data.status && (
                      <span class="project-card-visual-status">
                        {formatStatus(project.data.status)}
                      </span>
                    )}
                  </div>
                </a>

                <div class="project-card-body">
                  <div class="project-card-top">
                    <div class="project-card-meta">
                      <p class="meta">{project.data.pubDate.toISOString().slice(0, 10)}</p>
                    </div>
                  </div>

                  <h2>
                    <a href={`/projects/${project.data.slug}`}>
                      {project.data.title}
                    </a>
                  </h2>

                  <p class="project-card-copy">{project.data.description}</p>

                  {project.data.tags.length > 0 && (
                    <ul class="tag-list project-card-tags">
                      {project.data.tags.map((tag) => (
                        <li>
                          <span class="tag">{tag}</span>
                        </li>
                      ))}
                    </ul>
                  )}

                  <ul class="card-links project-card-links">
                    <li>
                      <a
                        class="project-card-link-primary"
                        href={`/projects/${project.data.slug}`}
                      >
                        Details
                      </a>
                    </li>
                    {project.data.githubUrl && project.data.githubUrl !== "" && (
                      <li>
                        <a
                          href={project.data.githubUrl}
                          target="_blank"
                          rel="noreferrer"
                        >
                          GitHub
                        </a>
                      </li>
                    )}
                    {project.data.demoUrl && project.data.demoUrl !== "" && (
                      <li>
                        <a
                          href={project.data.demoUrl}
                          target="_blank"
                          rel="noreferrer"
                        >
                          Demo
                        </a>
                      </li>
                    )}
                  </ul>
                </div>
              </article>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>
