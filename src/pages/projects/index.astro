---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const projects = await getCollection("projects");
const publishedProjects = projects
  .filter((project) => !project.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="Projects | jhle0" description="Projects archive">
  <section>
    <h1>Projects</h1>
    <p>A collection of projects, experiments, and things I have built.</p>
  </section>

  <section>
    {
      publishedProjects.length === 0 ? (
        <p>No projects found.</p>
      ) : (
        <ul class="card-list">
          {publishedProjects.map((project) => (
            <li>
              <article>
                <h2>
                  <a href={`/projects/${project.data.slug}`}>
                    {project.data.title}
                  </a>
                </h2>

                <p>{project.data.description}</p>

                <p class="meta">
                  {project.data.pubDate.toISOString().slice(0, 10)}
                  {project.data.status && (
                    <>
                      {" "}
                      · <strong>{project.data.status}</strong>
                    </>
                  )}
                </p>

                {project.data.tags.length > 0 && (
                  <ul class="tag-list">
                    {project.data.tags.map((tag) => (
                      <li>
                        <span class="tag">{tag}</span>
                      </li>
                    ))}
                  </ul>
                )}

                <ul class="card-links">
                  <li>
                    <a href={`/projects/${project.data.slug}`}>Details</a>
                  </li>
                  {project.data.githubUrl && project.data.githubUrl !== "" && (
                    <li>
                      <a
                        href={project.data.githubUrl}
                        target="_blank"
                        rel="noreferrer"
                      >
                        GitHub
                      </a>
                    </li>
                  )}
                  {project.data.demoUrl && project.data.demoUrl !== "" && (
                    <li>
                      <a
                        href={project.data.demoUrl}
                        target="_blank"
                        rel="noreferrer"
                      >
                        Demo
                      </a>
                    </li>
                  )}
                </ul>
              </article>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>
